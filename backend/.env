# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./verdict2action.db

# AI Keys (at least one required for real AI)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# JWT Auth
JWT_SECRET=verdict2action-hackathon-secret-key-2024
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# Storage
UPLOAD_DIR=./uploads
GENERATED_DIR=./generated

# AI Provider: "openai" or "gemini" or "mock"
AI_PROVIDER=mock

# OCR Provider: "paddle" or "tesseract"
OCR_PROVIDER=tesseract

# App
APP_ENV=development
LOG_LEVEL=INFO
